# Root HARNESS git repo. Tracks only the agent/dev-workflow harness:
# AGENTS.md, CLAUDE.md, justfile, scripts/, engine/, main-brain/, second-brain/, .claude/, .codex/,
# ignore files, the graphify guide, and harness history under docs/harness/. Everything heavy,
# generated, secret, or owned by another git repo is excluded.

# --- Nested git repos (own their own history) ---
/myhospital-fe/
/myhospital-be/

# --- Worktrees and their nested repos ---
/worktrees/

# --- Generated / large / data / backups ---
/graphify-out/
/_db-backups/
/.harness-backups/
/.linux-migration-backups/
/.obsidian/
/specs/

# --- docs: track the graphify guide + harness history; not work artifacts/captures ---
/docs/*
!/docs/graphify-agent-guide.md
!/docs/harness/
docs/harness/archive/removed-runtime/

# --- main-brain owner-gated promotion marker (transient; created by /promote, removed after) ---
main-brain/.promote-unlock

# --- Secrets / auth / runtime captures (anywhere) ---
*.har
session-auth.json
*-auth.json
*.cookies.json
.env
.env.*
*.secret
*.pem
*.key
*.log
*.tmp

# --- Caches / build output ---
__pycache__/
*.pyc
node_modules/
.promptfoo/
dist/
build/
bin/
obj/
.next/
.vite/
coverage/

# --- SDLC workflows (impact-analysis/bug-fix/technical-design/task-slicing/incremental-impl):
#     track the workflow SOURCE, ignore per-run round artifacts (envelopes/payloads). ---
engine/workflows/*/rounds/

# --- robust-test runtime output: keep workflow source, ignore per-run test artifacts. ---
engine/workflows/robust-test/runs/

# --- Promptfoo eval outputs: keep configs, ignore volatile run results. ---
docs/harness/promptfoo/results/*
!docs/harness/promptfoo/results/.gitkeep

# --- Runtime locks ---
.claude/scheduled_tasks.lock
.aider*
