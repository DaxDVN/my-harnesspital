# Root HARNESS git repo. Tracks only the agent/dev-workflow harness:
# AGENTS.md, CLAUDE.md, justfile, scripts/, engine/, main-brain/, second-brain/, .claude/, .codex/,
# ignore files, the graphify guide, and harness history under docs/harness/. Everything heavy,
# generated, secret, or owned by another git repo is excluded.

# --- Nested git repos (own their own history) ---
/myhospital-fe/
/myhospital-be/

# --- Worktrees and their nested repos ---
/worktrees/

# --- Generated / large / data / backups ---
/graphify-out/
/_db-backups/
/.harness-backups/
/.linux-migration-backups/
/.obsidian/
/.idea/
/specs/
/temp/

# --- Large generated SQL/CSV data dumps (keep the generator .py tracked, ignore the dumps) ---
scripts/*.sql
scripts/*.csv

# --- docs: track the graphify guide + harness history; not work artifacts/captures ---
/docs/*
!/docs/graphify-agent-guide.md
!/docs/harness/
docs/harness/archive/removed-runtime/

# --- main-brain owner-gated promotion marker (transient; created by /promote, removed after) ---
main-brain/.promote-unlock

# --- Secrets / auth / runtime captures (anywhere) ---
*.har
session-auth.json
*-auth.json
*.cookies.json
.env
.env.*
*.secret
*.pem
*.key
*.log
*.tmp

# --- Caches / build output ---
__pycache__/
*.pyc
node_modules/
.promptfoo/
dist/
build/
bin/
obj/
.next/
.vite/
coverage/

# --- Workflow runtime output: keep the workflow SOURCE tracked, ignore per-run artifacts
#     (runs/envelopes/payloads/rounds) across ALL workflows
#     (espresso-test, robust-test, pm-orchestrator, SDLC impact-analysis/bug-fix/etc.). ---
engine/workflows/*/runs/

# --- Promptfoo eval outputs: keep configs, ignore volatile run results. ---
docs/harness/promptfoo/results/*
!docs/harness/promptfoo/results/.gitkeep

# --- Runtime locks ---
.claude/scheduled_tasks.lock
.aider*

# --- PM orchestrator runtime (Fugu): transient markers + per-run ledgers; workflow source stays tracked
#     (per-run output dirs are covered by the generic engine/workflows/*/runs/ rule above). ---
.claude/.pm-run-active
.claude/.orchestrator_invariants.heartbeat

# --- OpenCode budget tally (scripts/oc_budget.py local usage cache; transient) ---
.claude/.oc_budget.json

# blind-PM direct-work escape marker (owner-toggled, never committed)
.direct-mode
