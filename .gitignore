# Root HARNESS git repo. Tracks only the agent/dev-workflow harness:
# AGENTS.md, CLAUDE.md, justfile, scripts/, engine/, main-brain/, second-brain/, .claude/, .codex/,
# ignore files, the graphify guide, and harness history under docs/harness/. Everything heavy,
# generated, secret, or owned by another git repo is excluded.

# --- Nested git repos (own their own history) ---
/myhospital-fe/
/myhospital-be/

# --- Worktrees and their nested repos ---
/worktrees/

# --- Generated / large / data / backups ---
/graphify-out/
/_db-backups/
/.harness-backups/
/.linux-migration-backups/
/.obsidian/
/specs/

# --- docs: track the graphify guide + harness history; not work artifacts/captures ---
/docs/*
!/docs/graphify-agent-guide.md
!/docs/harness/

# --- main-brain owner-gated promotion marker (transient; created by /promote, removed after) ---
main-brain/.promote-unlock

# --- Secrets / auth / runtime captures (anywhere) ---
*.har
session-auth.json
*-auth.json
*.cookies.json
.env
.env.*
*.secret
*.pem
*.key
*.log
*.tmp

# --- Caches / build output ---
__pycache__/
*.pyc
node_modules/
dist/
build/
bin/
obj/
.next/
coverage/

# --- agentflow-opencode subsystem (engine/workflows): track SOURCE; the global bin/ rule above
#     would hide its wrappers, so re-include .agentflow/bin/; exclude the 73M vendored agent-browser
#     package + per-round runtime output (re-vendor agent-browser on a fresh clone — see its NOTES). ---
!engine/workflows/agentflow-opencode/.agentflow/bin/
engine/workflows/agentflow-opencode/.agentflow/vendor/
engine/workflows/agentflow-opencode/.agentflow/rounds/round-*/

# --- Runtime locks ---
.claude/scheduled_tasks.lock
.aider*
