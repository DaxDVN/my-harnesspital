// MyHospital ORCHESTRATOR layout (repo-managed copy).
// Role: read / analyze / plan / review / coordinate. Opens shells only —
// it never auto-starts a dev server. Referenced by scripts/fish helpers
// (zorch) via absolute path, and installable to ~/.config/zellij/layouts/
// with `just z-install-layouts`.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="orch" focus=true {
        pane name="Orchestrator Agent" {
            command "fish"
            args "-c" "echo 'ORCHESTRATOR SESSION'; echo 'Run: claude / codex / gemini'; echo 'Role: analyze, plan, review, cross-check'; echo; exec fish"
        }
    }

    tab name="be" {
        pane name="Backend Read/Review" cwd="be" {
            command "fish"
            args "-c" "echo 'Backend worktree shell'; echo 'Use: rg, git diff, dotnet test when needed'; echo; exec fish"
        }
    }

    tab name="fe" {
        pane name="Frontend Read/Review" cwd="fe" {
            command "fish"
            args "-c" "echo 'Frontend worktree shell'; echo 'Use: rg, git diff, npm scripts when needed'; echo; exec fish"
        }
    }

    tab name="review" {
        pane split_direction="vertical" {
            pane name="BE Review" cwd="be" {
                command "fish"
                args "-c" "echo 'BE review shell'; echo 'Useful: git status --short; git diff; lazygit'; echo; exec fish"
            }
            pane name="FE Review" cwd="fe" {
                command "fish"
                args "-c" "echo 'FE review shell'; echo 'Useful: git status --short; git diff; lazygit'; echo; exec fish"
            }
        }
    }
}
