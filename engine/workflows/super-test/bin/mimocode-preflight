#!/usr/bin/env bash
# Read-only readiness check for the MiMoCode/OpenCode Super-Test driver path.
# Default: fail only on hard blockers. Use --strict to also fail on warnings.
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
STROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ROOT="$(cd "$STROOT/../../.." && pwd)"

# shellcheck source=/dev/null
. "$SCRIPT_DIR/_executor-lib.sh"

STRICT=0
for arg in "$@"; do
  case "$arg" in
    --strict) STRICT=1 ;;
    -h|--help)
      cat <<'EOF'
usage: mimocode-preflight [--strict]

Checks Super-Test executor readiness without starting a browser sweep:
- required harness files and wrapper bins
- selected executor runtime (opencode or mimo-code)
- agent-browser shim visibility
- MiMoCode command template safety
- target URL / target worktree enforcement hints

Environment:
  SUPERTEST_RUNTIME=auto|opencode|mimo-code
  SUPERTEST_CLI_MODEL=xiaomi-token-plan-sgp/mimo-v2.5
  SUPERTEST_MIMO_CODE_BIN=mimo
  SUPERTEST_MIMO_CODE_CMD='mimo run ... {prompt_file}'
  SUPERTEST_OPENCODE_RETRY_ATTEMPTS=2
  SUPERTEST_OPENCODE_RETRY_DELAY_SECS=5
  SUPERTEST_OPENCODE_RUN_TIMEOUT_SECS=1800
  SUPERTEST_OPENCODE_TIMEOUT_KILL_AFTER_SECS=30
  AGENTFLOW_TARGET_URL=http://...
  SUPERTEST_TARGET_REPO=/path/to/worktrees/<slug>/fe-or-be
EOF
      exit 0
      ;;
  esac
done

OKS=0
WARNS=0
FAILS=0

ok() { OKS=$((OKS + 1)); printf '[OK]   %s\n' "$*"; }
warn() { WARNS=$((WARNS + 1)); printf '[WARN] %s\n' "$*"; }
fail() { FAILS=$((FAILS + 1)); printf '[FAIL] %s\n' "$*"; }

need_file() {
  local rel="$1"
  if [ -f "$ROOT/$rel" ]; then ok "file:$rel"; else fail "missing file:$rel"; fi
}

need_exec() {
  local rel="$1"
  if [ -x "$ROOT/$rel" ]; then ok "exec:$rel"; elif [ -e "$ROOT/$rel" ]; then fail "not executable:$rel"; else fail "missing exec:$rel"; fi
}

need_cmd() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then ok "cmd:$cmd"; else fail "missing command:$cmd"; fi
}

export PATH="$STROOT/../progressive-test/.agentflow/bin:$PATH"

echo "Super-Test MiMoCode preflight — $ROOT"

need_cmd git
need_cmd python3
need_file AGENTS.md
need_file engine/workflows/super-test/config.yaml
need_file engine/workflows/super-test/protocol/harvest-sweep.md
need_file engine/workflows/super-test/integrations/mimocode-super-test.md
need_file engine/workflows/_shared/allowlist-check.py
need_exec engine/workflows/super-test/bin/supertest
need_exec engine/workflows/super-test/bin/sweep
need_exec engine/workflows/super-test/bin/repair
need_exec engine/workflows/super-test/bin/retest
need_exec engine/workflows/super-test/bin/call-opus-batch-rca
need_exec engine/workflows/super-test/bin/call-codex-review
need_exec engine/workflows/super-test/bin/agent-browser-evidence

brief="$ROOT/engine/workflows/super-test/integrations/mimocode-super-test.md"
if [ -f "$brief" ]; then
  grep -qi 'AGENTS.md' "$brief" && ok "brief:loads AGENTS.md" || fail "brief does not explicitly require AGENTS.md"
  grep -qi 'allowlist' "$brief" && ok "brief:allowlist boundary" || fail "brief does not mention allowlist boundary"
  grep -qi 'no source edits\|source edits' "$brief" && ok "brief:harvest source-edit boundary" || fail "brief does not mention source-edit boundary"
  grep -qi 'agent-browser' "$brief" && ok "brief:agent-browser" || fail "brief does not mention agent-browser"
  grep -qi 'agent-browser-evidence' "$brief" && ok "brief:anti-stall evidence fallback" || fail "brief does not mention agent-browser-evidence fallback"
fi

rt="$(supertest_runtime)"
case "$rt" in
  opencode)
    command -v opencode >/dev/null 2>&1 && ok "runtime:opencode" || fail "runtime selected opencode but opencode is not on PATH"
    ok "model:${SUPERTEST_CLI_MODEL:-xiaomi-token-plan-sgp/mimo-v2.5}"
    ;;
  mimo-code)
    if [ -n "${SUPERTEST_MIMO_CODE_CMD:-}" ]; then
      case "$SUPERTEST_MIMO_CODE_CMD" in
        *'{prompt_file}'*) ok "runtime:mimo-code cmd template contains {prompt_file}" ;;
        *) fail "SUPERTEST_MIMO_CODE_CMD must include {prompt_file}, otherwise the generated driver prompt is not passed" ;;
      esac
    else
      bin="${SUPERTEST_MIMO_CODE_BIN:-mimo}"
      command -v "$bin" >/dev/null 2>&1 && ok "runtime:mimo-code bin:$bin" || fail "runtime selected mimo-code but '$bin' is not on PATH; set SUPERTEST_MIMO_CODE_BIN or SUPERTEST_MIMO_CODE_CMD"
    fi
    ;;
  none)
    fail "no executor runtime found; install opencode or configure SUPERTEST_RUNTIME=mimo-code"
    ;;
  *)
    fail "unknown SUPERTEST_RUNTIME resolved to '$rt'"
    ;;
esac

if command -v agent-browser >/dev/null 2>&1; then
  ok "agent-browser:on PATH"
else
  fail "agent-browser not found; expected progressive-test shim at engine/workflows/progressive-test/.agentflow/bin/agent-browser"
fi

target_url="${AGENTFLOW_TARGET_URL:-${SUPERTEST_TARGET_URL:-}}"
if [ -n "$target_url" ]; then
  ok "target-url:set"
else
  warn "target URL unset; set AGENTFLOW_TARGET_URL or SUPERTEST_TARGET_URL before sweep/retest"
fi

target_repo="${SUPERTEST_TARGET_REPO:-}"
if [ -z "$target_repo" ]; then
  warn "SUPERTEST_TARGET_REPO unset; sweep can run, but no-source-edit enforcement is skipped"
else
  if [ ! -d "$target_repo" ]; then
    fail "SUPERTEST_TARGET_REPO does not exist: $target_repo"
  else
    target_real="$(cd "$target_repo" && pwd -P)"
    main_fe=""
    main_be=""
    [ -d "$ROOT/myhospital-fe" ] && main_fe="$(cd "$ROOT/myhospital-fe" && pwd -P)"
    [ -d "$ROOT/myhospital-be" ] && main_be="$(cd "$ROOT/myhospital-be" && pwd -P)"
    if [ "$target_real" = "$main_fe" ] || [ "$target_real" = "$main_be" ]; then
      fail "SUPERTEST_TARGET_REPO points at a main repo; Super-Test implementation must use worktrees/<slug>/fe-or-be"
    elif [[ "$target_real" == "$ROOT/worktrees/"* ]]; then
      ok "target-repo:worktree"
    else
      warn "SUPERTEST_TARGET_REPO is not under this workspace's worktrees/: $target_real"
    fi
  fi
fi

printf 'Summary: %s OK, %s WARN, %s FAIL\n' "$OKS" "$WARNS" "$FAILS"
if [ "$FAILS" -gt 0 ]; then
  exit 1
fi
if [ "$STRICT" -eq 1 ] && [ "$WARNS" -gt 0 ]; then
  exit 1
fi
exit 0
