#!/usr/bin/env bash
# Super-Test M2 — Opus (or MiMo) file-hands-off the repair plan to Codex for review. Status-only return.
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
STROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB="$STROOT/lib/supertest.py"
MODULE="${1:-}"; RUN="${2:-}"
[ -n "$MODULE" ] && [ -n "$RUN" ] || { echo "usage: $(basename "$0") <module> <run-id>" >&2; exit 2; }
RUN_DIR="$STROOT/runs/$MODULE/$RUN"; LOG="$RUN_DIR/logs"; mkdir -p "$LOG"
RCA="$RUN_DIR/08-opus-batch-rca.md"; OUT="$RUN_DIR/09-codex-review.md"
[ -f "$RCA" ] || { echo "BATCH_RCA_MISSING: $RCA" >&2; exit 2; }
python3 "$LIB" set-state "$RUN_DIR" CODEX_REVIEW >/dev/null

PROMPT="Review the Super-Test repair plan at $RCA against the codebase + conventions (engine/rules/backend.md, frontend.md). Check root-cause completeness, side effects, convention compliance, and that batches stay in their allowlists. Write $OUT with a '## Verdict' of APPROVE | APPROVE_WITH_CHANGES | REJECT + required changes + side effects. Return ONLY: STATUS=CODEX_REVIEW_READY VERDICT=<verdict>"

if command -v codex >/dev/null 2>&1; then
  codex exec "$PROMPT" >"$LOG/codex.stdout.log" 2>"$LOG/codex.stderr.log" || { echo "CODEX_RUN_FAILED (see $LOG/codex.stderr.log)" >&2; exit 1; }
elif command -v claude >/dev/null 2>&1; then
  echo "NOTE: codex CLI not found — fallback to a Claude review pass." >&2
  claude -p "$PROMPT" --model claude-opus-4-8 >"$LOG/codex.stdout.log" 2>"$LOG/codex.stderr.log" || true
else
  echo "CODEX/CLAUDE not found — manual: review $RCA, write $OUT with a Verdict." >&2
fi

[ -f "$OUT" ] || { echo "STATUS=CODEX_PENDING ($OUT not written)"; exit 3; }
python3 "$LIB" validate codex-review "$OUT" || { echo "codex review INVALID" >&2; exit 1; }
verdict="$(grep -oiE 'APPROVE_WITH_CHANGES|APPROVE|REJECT' "$OUT" | head -1 || echo UNKNOWN)"
echo "STATUS=CODEX_REVIEW_READY VERDICT=$verdict ARTIFACT=$OUT"
