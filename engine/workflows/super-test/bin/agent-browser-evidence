#!/usr/bin/env bash
# Collect bounded agent-browser evidence for MiMo/OpenCode Super-Test.
# Best-effort by design: one failed probe must not stall the whole sweep.
set -euo pipefail

usage() {
  cat <<'EOF'
usage: agent-browser-evidence --out-dir <dir> [--url <url>] [--session <name>] [--selector <css>] [--max-output <chars>]

Collects bounded evidence files for a browser flow:
- url/title
- full and interactive accessibility snapshots
- optional selector-scoped snapshot
- screenshot
- console/errors/network
- DOM row/text summary for virtualized tables and grids

Environment:
  AGENT_BROWSER_BIN        Override agent-browser binary path.
  AGENT_BROWSER_SESSION    Browser session name, also accepted via --session.
  AGENT_BROWSER_MAX_OUTPUT Output bound, also accepted via --max-output.
EOF
}

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
DEFAULT_AB="$ROOT/engine/workflows/progressive-test/.agentflow/bin/agent-browser"

AB="${AGENT_BROWSER_BIN:-$DEFAULT_AB}"
SESSION="${AGENT_BROWSER_SESSION:-super-test}"
OUT_DIR=""
URL=""
SELECTOR=""
MAX_OUTPUT="${AGENT_BROWSER_MAX_OUTPUT:-12000}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --out-dir)
      OUT_DIR="${2:-}"; shift 2 ;;
    --url)
      URL="${2:-}"; shift 2 ;;
    --session)
      SESSION="${2:-}"; shift 2 ;;
    --selector)
      SELECTOR="${2:-}"; shift 2 ;;
    --max-output)
      MAX_OUTPUT="${2:-}"; shift 2 ;;
    -h|--help)
      usage; exit 0 ;;
    *)
      echo "unknown arg: $1" >&2
      usage >&2
      exit 2 ;;
  esac
done

[ -n "$OUT_DIR" ] || { echo "--out-dir is required" >&2; exit 2; }
[ -x "$AB" ] || { echo "agent-browser not executable: $AB" >&2; exit 127; }

mkdir -p "$OUT_DIR"

run_ab() {
  AGENT_BROWSER_SESSION="$SESSION" AGENT_BROWSER_MAX_OUTPUT="$MAX_OUTPUT" "$AB" "$@"
}

capture() {
  local name="$1"; shift
  local path="$OUT_DIR/$name"
  {
    printf '$ agent-browser'
    printf ' %q' "$@"
    printf '\n\n'
    run_ab "$@"
  } >"$path" 2>&1 || {
    code=$?
    {
      printf '\n[agent-browser-evidence] command failed with exit %s\n' "$code"
    } >>"$path"
    return 0
  }
}

if [ -n "$URL" ]; then
  capture "00-open.txt" open "$URL"
fi

capture "01-url.txt" get url
capture "02-title.txt" get title
capture "03-snapshot.txt" snapshot
capture "04-snapshot-interactive.txt" snapshot -i -c
capture "05-snapshot-dialogs.txt" snapshot -s '[role="dialog"], [role="alertdialog"]' -c

if [ -n "$SELECTOR" ]; then
  capture "06-snapshot-selector.txt" snapshot -s "$SELECTOR" -c
fi

capture "06-screenshot.txt" screenshot "$OUT_DIR/screenshot.png"
capture "07-console.txt" console
capture "08-errors.txt" errors
capture "09-network.txt" network requests

dom_js="$(cat <<'JS'
(() => {
  const selectors = [
    '[role="row"]',
    '[role="gridcell"]',
    '[role="cell"]',
    'table tr',
    'tbody tr',
    '[data-rowindex]',
    '[data-testid*="row" i]',
    '[class*="row" i]'
  ];
  const seen = new Set();
  const groups = [];
  for (const selector of selectors) {
    const nodes = Array.from(document.querySelectorAll(selector)).slice(0, 30);
    const items = [];
    for (const [index, el] of nodes.entries()) {
      const key = `${selector}:${index}:${(el.textContent || '').slice(0, 120)}`;
      if (seen.has(key)) continue;
      seen.add(key);
      const text = (el.innerText || el.textContent || '').replace(/\s+/g, ' ').trim();
      const aria = el.getAttribute('aria-label') || '';
      if (!text && !aria) continue;
      items.push({
        index,
        tag: el.tagName.toLowerCase(),
        role: el.getAttribute('role'),
        aria,
        text: text.slice(0, 500)
      });
    }
    groups.push({ selector, matched: nodes.length, sampled: items.length, items });
  }
  return JSON.stringify({
    href: location.href,
    title: document.title,
    bodyTextSample: (document.body?.innerText || '').replace(/\s+/g, ' ').trim().slice(0, 1000),
    groups
  }, null, 2);
})()
JS
)"
capture "10-dom-summary.json" eval "$dom_js"

{
  echo "# agent-browser evidence"
  echo "- Session: $SESSION"
  echo "- Output dir: $OUT_DIR"
  echo "- URL target: ${URL:-current page}"
  echo "- Selector: ${SELECTOR:-none}"
  echo "- Max output: $MAX_OUTPUT"
  echo
  echo "Files:"
  find "$OUT_DIR" -maxdepth 1 -type f -printf '- %f (%s bytes)\n' | sort
} >"$OUT_DIR/README.md"

echo "EVIDENCE_DIR=$OUT_DIR"
