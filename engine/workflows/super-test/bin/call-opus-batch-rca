#!/usr/bin/env bash
# Super-Test M2 — MiMo file-hands-off to Opus (batch-RCA). Short prompt; content in files; status-only return.
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
STROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ROOT="$(cd "$STROOT/../../.." && pwd)"
LIB="$STROOT/lib/supertest.py"
AGENT="$ROOT/engine/agents/mh-batch-rca.md"
MODULE="${1:-}"; RUN="${2:-}"
[ -n "$MODULE" ] && [ -n "$RUN" ] || { echo "usage: $(basename "$0") <module> <run-id>" >&2; exit 2; }
RUN_DIR="$STROOT/runs/$MODULE/$RUN"; LOG="$RUN_DIR/logs"; mkdir -p "$LOG"
REQ="$RUN_DIR/07-opus-request.md"
[ -f "$REQ" ] || { echo "OPUS_REQUEST_MISSING: $REQ — run a harvest sweep to a stop condition first" >&2; exit 2; }
python3 "$LIB" set-state "$RUN_DIR" OPUS_BATCH_RCA >/dev/null

PROMPT="You are mh-batch-rca (read the agent spec at $AGENT and obey it). Read $REQ and the artifacts it lists. Do batch cluster-RCA + repair batches. Write $RUN_DIR/08-opus-batch-rca.md and $RUN_DIR/10-approved-repair-plan.md. For risky batches run: $SCRIPT_DIR/call-codex-review $MODULE $RUN. Return ONLY: STATUS=APPROVED_REPAIR_PLAN_READY ARTIFACT=$RUN_DIR/10-approved-repair-plan.md"

if command -v claude >/dev/null 2>&1; then
  # Headless agentic run: Opus reads artifacts, writes 08+10, may call codex. It MUST bypass interactive
  # permission — a headless `claude -p` cannot answer a permission prompt, so default mode HANGS on the first
  # tool call (this was the "timeout, no output" symptom — NOT the model id, which is valid). The PreToolUse
  # guard hook still fires under bypassPermissions, so the hard BLOCKs (git mutation / rm -rf / dep install)
  # stay enforced. Timeout is generous: a real batch-RCA is minutes, not the ~300s a caller might cap.
  echo "[call-opus-batch-rca] launching headless Opus (agentic; minutes not seconds)…" >&2
  CL_TIMEOUT="${SUPERTEST_OPUS_TIMEOUT:-1800}"; ok=0
  for attempt in 1 2; do
    if timeout "$CL_TIMEOUT" claude -p "$PROMPT" \
         --model "${SUPERTEST_CLAUDE_MODEL:-opus}" \
         --permission-mode bypassPermissions \
         --max-turns "${SUPERTEST_OPUS_MAX_TURNS:-80}" \
         --add-dir "$ROOT" \
         >"$LOG/opus-rca.stdout.log" 2>"$LOG/opus-rca.stderr.log"; then
      ok=1; break
    fi
    rc=$?
    echo "[call-opus-batch-rca] attempt $attempt failed rc=$rc$([ "$rc" = 124 ] && echo " (=${CL_TIMEOUT}s timeout; raise SUPERTEST_OPUS_TIMEOUT)") — log: $LOG/opus-rca.stderr.log" >&2
  done
  [ "$ok" = 1 ] || { echo "OPUS_RUN_FAILED after 2 attempts (see $LOG/opus-rca.stderr.log)" >&2; exit 1; }
else
  echo "CLAUDE_CLI_NOT_FOUND — manual handoff: open Claude/Opus (max effort), read $REQ + obey $AGENT, write 08 + 10." >&2
fi

[ -f "$RUN_DIR/10-approved-repair-plan.md" ] || { echo "STATUS=OPUS_PENDING (10-approved-repair-plan.md not written yet)"; exit 3; }
python3 "$LIB" validate approved-repair-plan "$RUN_DIR/10-approved-repair-plan.md" || { echo "approved plan INVALID" >&2; exit 1; }
python3 "$LIB" set-state "$RUN_DIR" APPROVED_REPAIR_PLAN >/dev/null
echo "STATUS=APPROVED_REPAIR_PLAN_READY ARTIFACT=$RUN_DIR/10-approved-repair-plan.md"
