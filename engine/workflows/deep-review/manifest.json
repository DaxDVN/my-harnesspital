{
  "name": "deep-review",
  "description": "Maximum-recall <=3-round partitioned code review (D1-D7): multi-pass convergence per dimension, exemplar anchors, self-adversarial pre-filter, adversarial verify, bounded completeness.",
  "kind": "workflow",
  "implementation_kind": "workflow-tool-js",
  "public_entry": true,
  "auto_route_allowed": false,
  "entry_skill": "mh-review",
  "recommended_prompt_file": "engine/prompts/deep-audit-orchestrator.md",
  "required_inputs": [
    "frozen review scope",
    "target module, diff, or worktree",
    "audit base name"
  ],
  "allowed_writes": [
    "docs/audit/**"
  ],
  "validators": [
    "python scripts/audit_path.py <base>",
    "engine/workflows/deep-review/findings-schema.md"
  ],
  "budget": {
    "max_context_files": 0,
    "max_payload_inline_chars": 0
  },
  "review_mode": {
    "default": "aggressive-weak-multipass",
    "passes_per_dimension_default": 3,
    "block_high_requires_adjudication": true
  },
  "workflow_script": "workflow.js",
  "agents": [
    "mh-reviewer"
  ],
  "external_agents": [],
  "skills_used": [],
  "rules": [
    "backend",
    "frontend",
    "ponytail",
    "quality-gates"
  ],
  "knowledge": [
    "engine/workflows/deep-review/protocol.md",
    "engine/workflows/deep-review/checklist.md",
    "engine/workflows/deep-review/findings-schema.md"
  ]
}
