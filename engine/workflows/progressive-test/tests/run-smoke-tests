#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
BIN=.agentflow/bin
CURRENT_STATE="$(python3 -c "import json; print(json.load(open('.agentflow/state.json'))['state'])")"
CURRENT_ROUND="$(python3 -c "import json; print(json.load(open('.agentflow/state.json'))['current_round'] or 'round-smoke-reset')")"
if [[ "$CURRENT_STATE" != "IDLE" && "$CURRENT_STATE" != "DONE" && "$CURRENT_STATE" != "FAILED" ]]; then
  $BIN/update-state "$CURRENT_ROUND" FAILED error=SMOKE_RESET >/dev/null
fi
ROUND="round-smoke-$(date +%s)-$$"; export ROUND
RD=".agentflow/rounds/$ROUND"
$BIN/init-round "$ROUND" "mock-login-flow"

# --- TEST_ONLY (mock) -> bug-packet (+ envelope emitted by the wrapper) ---
AGENTFLOW_MOCK_OPENCODE=1 $BIN/test-with-opencode "$ROUND"
$BIN/validate-artifact bug-packet "$RD/01-bug-packet.json"
$BIN/validate-envelope "$RD/01-bug-packet.envelope.json"

# --- triage: the mock bug ('disabled state did not clear') is NOT a trivial signature -> NEEDS_RCA ---
ROUTE="$($BIN/classify "$ROUND")"; echo "$ROUTE"
case "$ROUTE" in *NEEDS_RCA*) : ;; *) echo "SMOKE FAIL: expected NEEDS_RCA, got: $ROUTE" >&2; exit 1;; esac

# --- RCA (mock = fixture, forced DIRECT_PATCH so no Codex needed) -> rca-plan + envelope ---
$BIN/update-state "$ROUND" RCA_RUNNING >/dev/null
cp tests/fixtures/sample-rca-plan.json "$RD/02-rca-plan.json"
python3 - <<'__RCA__'
import json, os
from pathlib import Path
p = Path('.agentflow/rounds') / os.environ['ROUND'] / '02-rca-plan.json'
d = json.loads(p.read_text()); d['round_id'] = os.environ['ROUND']; d['verdict'] = 'DIRECT_PATCH'; d['requires_codex_review'] = False
p.write_text(json.dumps(d, indent=2) + '\n')
__RCA__
$BIN/validate-artifact rca-plan "$RD/02-rca-plan.json"
$BIN/write-envelope rca-plan "$RD/02-rca-plan.json" >/dev/null
$BIN/validate-envelope "$RD/02-rca-plan.envelope.json"
$BIN/update-state "$ROUND" RCA_PLAN_READY rca_plan="$RD/02-rca-plan.json" >/dev/null

# --- P4: build approved plan FROM the rca-plan -> approved-plan + envelope ---
$BIN/build-approved-plan "$ROUND"
test -f "$RD/04-approved-plan.md" || { echo "SMOKE FAIL: build-approved-plan produced no plan" >&2; exit 1; }
$BIN/write-envelope approved-plan "$RD/04-approved-plan.md" >/dev/null
$BIN/validate-envelope "$RD/04-approved-plan.envelope.json"
$BIN/update-state "$ROUND" DIRECT_PATCH_APPROVED approved_plan="$RD/04-approved-plan.md" >/dev/null

# --- IMPLEMENT_ONLY (mock) -> impl-report (+ envelope) ---
AGENTFLOW_MOCK_OPENCODE=1 $BIN/implement-with-opencode "$ROUND"
$BIN/validate-artifact implementation-report "$RD/05-implementation-report.json"
$BIN/validate-envelope "$RD/05-implementation-report.envelope.json"

# --- RETEST_ONLY (mock) -> retest-report (+ envelope) ---
AGENTFLOW_MOCK_OPENCODE=1 $BIN/retest-with-opencode "$ROUND"
$BIN/validate-artifact retest-report "$RD/06-retest-report.json"
$BIN/validate-envelope "$RD/06-retest-report.envelope.json"

$BIN/summarize-round "$ROUND"
test -f "$RD/07-final-round-summary.md"
$BIN/validate-artifact state .agentflow/state.json

# --- triage fast-lane: a trivial bug-packet (undefined symbol) -> classify TRIVIAL + writes a plan ---
TROUND="round-smoke-trivial-$(date +%s)-$$"; TRD=".agentflow/rounds/$TROUND"; mkdir -p "$TRD/logs"
TROUND="$TROUND" python3 - <<'__TRIV__'
import json, os
from pathlib import Path
t = os.environ['TROUND']
bp = {"round_id": t, "scenario": "trivial-undefined", "status": "FAIL", "route": "/x",
      "steps_to_reproduce": ["open /x"], "expected": "renders", "actual": "crash",
      "evidence": {"browser_snapshot_excerpt": "", "console_errors": ["ReferenceError: SaveButton is not defined"],
                   "network_errors": [], "screenshot_paths": [], "video_path": None, "agent_browser_logs": []},
      "reproducibility": "ALWAYS", "executor_notes": {"root_cause_hypothesis": None, "classification": None}}
Path(".agentflow/rounds")/t/"01-bug-packet.json"
Path(f".agentflow/rounds/{t}/01-bug-packet.json").write_text(json.dumps(bp, indent=2) + "\n")
__TRIV__
$BIN/validate-artifact bug-packet "$TRD/01-bug-packet.json"
TROUTE="$($BIN/classify "$TROUND")"; echo "$TROUTE"
case "$TROUTE" in *TRIVIAL*) : ;; *) echo "SMOKE FAIL: expected TRIVIAL, got: $TROUTE" >&2; exit 1;; esac
test -f "$TRD/04-approved-plan.md" || { echo "SMOKE FAIL: trivial fast-lane wrote no plan" >&2; exit 1; }

printf 'SMOKE TEST PASS\n'
