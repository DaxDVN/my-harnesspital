#!/usr/bin/env python3
from __future__ import annotations
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[2]
LOCAL_BIN = ROOT / ".agentflow" / "bin"
PROBE_PATH = f"{LOCAL_BIN}:{os.environ.get('PATH','')}"
EXPECTED_PROVIDER = "xiaomi-token-plan-sgp"
EXPECTED_CLI_MODEL = f"{EXPECTED_PROVIDER}/mimo-v2.5"

def run(args: list[str]) -> tuple[int, str, str]:
    env = os.environ.copy()
    env["PATH"] = PROBE_PATH
    proc = subprocess.run(args, cwd=ROOT, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=30, env=env)
    return proc.returncode, proc.stdout, proc.stderr

def main() -> int:
    agent_browser_path = shutil.which("agent-browser", path=PROBE_PATH)
    result = {
        "opencode": {"available": shutil.which("opencode") is not None, "path": shutil.which("opencode")},
        "models": {"required_provider": EXPECTED_PROVIDER, "required_cli_model": EXPECTED_CLI_MODEL, "available": False, "raw": []},
        "mcp": {"servers": [], "has_browser_like_server": False, "raw": ""},
        "agents": {"has_webfetch": False, "has_websearch": False, "has_bash": False, "has_agent_browser": False, "raw_excerpt": ""},
        "agent_browser": {"available": agent_browser_path is not None, "path": agent_browser_path, "version": None, "skills": [], "chrome_path": str(Path.home() / ".agent-browser" / "browsers" / "chrome-149.0.7827.115"), "chrome_installed": (Path.home() / ".agent-browser" / "browsers" / "chrome-149.0.7827.115").exists()},
        "binaries": {"agent-browser": agent_browser_path, "chromium": shutil.which("chromium"), "google-chrome": shutil.which("google-chrome"), "firefox": shutil.which("firefox")},
        "verdict": "UNKNOWN",
        "blocking_gaps": [],
        "notes": []
    }
    if agent_browser_path:
        code, out, err = run(["agent-browser", "--version"])
        if code == 0:
            result["agent_browser"]["version"] = out.strip()
        code, out, err = run(["agent-browser", "skills", "list"])
        if code == 0:
            result["agent_browser"]["skills"] = [line.strip() for line in out.splitlines() if line.strip()][:20]
    if result["opencode"]["available"]:
        code, out, err = run(["opencode", "models", EXPECTED_PROVIDER])
        if code == 0:
            models = [line.strip() for line in out.splitlines() if line.strip()]
            result["models"]["raw"] = models
            result["models"]["available"] = EXPECTED_CLI_MODEL in models
        code, out, err = run(["opencode", "mcp", "list"])
        result["mcp"]["raw"] = out + err
        lower_mcp = result["mcp"]["raw"].lower()
        result["mcp"]["has_browser_like_server"] = any(x in lower_mcp for x in ["agent-browser", "playwright", "puppeteer", "browser"])
        result["mcp"]["servers"] = [line.strip() for line in result["mcp"]["raw"].splitlines() if line.strip() and "server" not in line.lower()][:20]
        code, out, err = run(["opencode", "agent", "list"])
        raw = out + err
        result["agents"]["raw_excerpt"] = raw[:4000]
        lower = raw.lower()
        result["agents"]["has_webfetch"] = "webfetch" in lower
        result["agents"]["has_websearch"] = "websearch" in lower
        result["agents"]["has_bash"] = "bash" in lower
        result["agents"]["has_agent_browser"] = "agent-browser" in lower
    if not result["opencode"]["available"]:
        result["blocking_gaps"].append("OPENCODE_NOT_FOUND")
    if not result["models"]["available"]:
        result["blocking_gaps"].append("MIMO_PROVIDER_MODEL_NOT_AVAILABLE")
    browser_binary = result["agent_browser"]["available"]
    if not browser_binary:
        result["blocking_gaps"].append("AGENT_BROWSER_NOT_AVAILABLE")
    if not result["agent_browser"]["chrome_installed"]:
        result["blocking_gaps"].append("AGENT_BROWSER_CHROME_NOT_INSTALLED")
    if result["agents"]["has_webfetch"]:
        result["notes"].append("OpenCode explore agent exposes webfetch; this can inspect web pages but is not browser automation.")
    if result["agents"]["has_websearch"]:
        result["notes"].append("OpenCode explore agent exposes websearch; this can search web but is not browser automation.")
    result["verdict"] = "READY_FOR_BROWSER_E2E" if not result["blocking_gaps"] else "MISSING_BROWSER_E2E_CAPABILITY"
    out_path = ROOT / ".agentflow" / "capabilities.json"
    out_path.write_text(json.dumps(result, indent=2) + "\n", encoding="utf-8")
    print(json.dumps(result, indent=2))
    return 0 if result["opencode"]["available"] and result["models"]["available"] else 1

if __name__ == "__main__":
    raise SystemExit(main())
