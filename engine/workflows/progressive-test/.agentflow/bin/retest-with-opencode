#!/usr/bin/env bash

set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
LIB="$ROOT/.agentflow/lib/agentflow.py"
SHARED_RETRY="$ROOT/../_shared/opencode-retry.sh"
export PATH="$ROOT/.agentflow/bin:$PATH"
ROUND_ID="${1:-}"
if [[ -z "$ROUND_ID" ]]; then echo "usage: $(basename "$0") <round-id>" >&2; exit 2; fi
ROUND_DIR="$ROOT/.agentflow/rounds/$ROUND_ID"
LOG_DIR="$ROUND_DIR/logs"
mkdir -p "$LOG_DIR"
MODEL="$(python3 "$LIB" config-value executor.model 2>/dev/null || true)"; MODEL="${MODEL:-mimo-v2.5}"
if [[ "$MODEL" != "mimo-v2.5" ]]; then echo "CONFIG_ERROR: executor.model must be mimo-v2.5 for MVP, got $MODEL" >&2; exit 1; fi
PROVIDER="$(python3 "$LIB" config-value executor.provider 2>/dev/null || true)"; PROVIDER="${PROVIDER:-mimo-token-plan}"
CLI_MODEL="$(python3 "$LIB" config-value executor.cli_model 2>/dev/null || true)"; CLI_MODEL="${CLI_MODEL:-$MODEL}"
if [[ "${AGENTFLOW_EXECUTOR_MODEL:-}" != "" && "${AGENTFLOW_EXECUTOR_MODEL}" != "$MODEL" ]]; then echo "MODEL_OVERRIDE_IGNORED_IN_MVP: requested ${AGENTFLOW_EXECUTOR_MODEL}; using $MODEL" >&2; fi
if [[ ! -f "$SHARED_RETRY" ]]; then echo "SHARED_RETRY_HELPER_MISSING: $SHARED_RETRY" >&2; exit 1; fi
# shellcheck source=/dev/null
. "$SHARED_RETRY"
real_opencode_prompt(){ local instruction="$1" mode="$2" output="$3"; local scenario target_url; scenario="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("scenario") or "")' "$ROOT/.agentflow/state.json" 2>/dev/null || true)"; target_url="${AGENTFLOW_TARGET_URL:-}"; cat "$instruction"; printf '\n\nRound ID: %s\nRound dir: %s\nScenario: %s\nTarget URL override: %s\nRequired output: %s\nMode: %s\nExecutor model: %s\nProvider: %s\nCLI model: %s\n' "$ROUND_ID" "$ROUND_DIR" "$scenario" "$target_url" "$output" "$mode" "$MODEL" "$PROVIDER" "$CLI_MODEL"; }
execute_opencode(){ local mode="$1" instruction="$2" output="$3" outlog="$4" errlog="$5"; if ! command -v opencode >/dev/null 2>&1; then echo "OPENCODE_NOT_FOUND" >"$errlog"; return 127; fi; local prompt; prompt="$(real_opencode_prompt "$instruction" "$mode" "$output")"; supertest_run_with_retry "$outlog" "$errlog" "" opencode run --model "$CLI_MODEL" "$prompt"; return $?; }
validate_or_fail(){ local kind="$1" output="$2" errlog="$3"; if [[ ! -f "$output" ]]; then echo "EXECUTOR_FAILED_NO_ARTIFACT: $output" >>"$errlog"; "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" FAILED error=EXECUTOR_FAILED_NO_ARTIFACT >/dev/null || true; exit 1; fi; if ! "$ROOT/.agentflow/bin/validate-artifact" "$kind" "$output" >>"$errlog" 2>&1; then echo "EXECUTOR_INVALID_ARTIFACT: $output" >>"$errlog"; "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" FAILED error=EXECUTOR_INVALID_ARTIFACT >/dev/null || true; exit 1; fi; }
has_agent_browser_capability(){ if command -v agent-browser >/dev/null 2>&1; then return 0; fi; local mcp agents; mcp="$(opencode mcp list 2>/dev/null || true)"; agents="$(opencode agent list 2>/dev/null || true)"; printf "%s\n%s" "$mcp" "$agents" | grep -Eiq "agent-browser|playwright|puppeteer|browser"; }
require_agent_browser_or_fail(){ local errlog="$1"; if [[ "${AGENTFLOW_REQUIRE_AGENT_BROWSER:-1}" != "1" ]]; then echo "AGENT_BROWSER_REQUIREMENT_SKIPPED" >>"$errlog"; return 0; fi; if ! has_agent_browser_capability; then echo "AGENT_BROWSER_NOT_AVAILABLE" >"$errlog"; echo "OpenCode has webfetch/websearch capability, but no agent-browser/playwright/puppeteer/browser MCP or agent-browser binary was detected." >>"$errlog"; "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" FAILED error=AGENT_BROWSER_NOT_AVAILABLE >/dev/null || true; exit 1; fi; }

INSTRUCTION="$ROOT/.agentflow/prompts-or-instructions/opencode-retest-only.md"; PLAN="$ROUND_DIR/04-approved-plan.md"; IMPL="$ROUND_DIR/05-implementation-report.json"; OUTPUT="$ROUND_DIR/06-retest-report.json"; STDOUT_LOG="$LOG_DIR/retest-with-opencode.stdout.log"; STDERR_LOG="$LOG_DIR/retest-with-opencode.stderr.log"
if [[ ! -f "$PLAN" ]]; then echo "APPROVED_PLAN_MISSING: $PLAN" >"$STDERR_LOG"; exit 1; fi
if [[ ! -f "$IMPL" ]]; then echo "IMPLEMENTATION_REPORT_MISSING: $IMPL" >"$STDERR_LOG"; exit 1; fi
require_agent_browser_or_fail "$STDERR_LOG"
"$ROOT/.agentflow/bin/update-state" "$ROUND_ID" RETESTING >/dev/null
if ! execute_opencode RETEST_ONLY "$INSTRUCTION" "$OUTPUT" "$STDOUT_LOG" "$STDERR_LOG"; then echo "EXECUTOR_FAILED_NO_ARTIFACT" >>"$STDERR_LOG"; "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" FAILED error=EXECUTOR_FAILED_NO_ARTIFACT >/dev/null || true; exit 1; fi
validate_or_fail retest-report "$OUTPUT" "$STDERR_LOG"
status="$(python3 -c "import json; print(json.load(open('$OUTPUT'))['status'])")"
if [[ "$status" == "PASS" ]]; then "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" RETEST_PASSED retest_report=".agentflow/rounds/$ROUND_ID/06-retest-report.json" >/dev/null; else "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" RETEST_FAILED retest_report=".agentflow/rounds/$ROUND_ID/06-retest-report.json" >/dev/null; fi
"$ROOT/.agentflow/bin/write-envelope" retest-report "$OUTPUT" >/dev/null
echo "Wrote $OUTPUT"
