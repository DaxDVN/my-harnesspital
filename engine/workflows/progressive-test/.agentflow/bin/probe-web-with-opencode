#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
URL="${1:-https://example.com}"
OUT="$ROOT/.agentflow/logs/web-probe-$(date +%s).json"
PROMPT="Use webfetch to inspect this URL: $URL. Return ONLY compact JSON with keys: url, title, visible_text_excerpt, tool_used, limitation. Do not write files."
CLI_MODEL="xiaomi-token-plan-sgp/mimo-v2.5"
if ! command -v opencode >/dev/null 2>&1; then
  echo "OPENCODE_NOT_FOUND" >&2
  exit 127
fi
# Use explore because local agent list shows webfetch/websearch on explore, not necessarily on build.
opencode run --agent explore --model "$CLI_MODEL" --format default "$PROMPT" | tee "$OUT"
echo "WROTE $OUT"
