#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
URL="${1:-https://example.com}"
TS="$(date +%s)"
SCREENSHOT="$ROOT/.agentflow/logs/firefox-probe-$TS.png"
LOG="$ROOT/.agentflow/logs/firefox-probe-$TS.log"
PROMPT="Use the bash tool to run exactly this command: timeout 60s firefox --headless --screenshot '$SCREENSHOT' '$URL'. Then return ONLY compact JSON with keys url, screenshot_path, tool_used, limitation, command_status. This is a Firefox headless probe, not agent-browser automation."
CLI_MODEL="xiaomi-token-plan-sgp/mimo-v2.5"
if ! command -v opencode >/dev/null 2>&1; then
  echo "OPENCODE_NOT_FOUND" >&2
  exit 127
fi
opencode run --model "$CLI_MODEL" "$PROMPT" | tee "$LOG"
if [[ -f "$SCREENSHOT" ]]; then
  echo "SCREENSHOT_CREATED $SCREENSHOT"
else
  echo "SCREENSHOT_NOT_CREATED $SCREENSHOT" >&2
  exit 1
fi
