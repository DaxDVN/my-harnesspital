#!/usr/bin/env bash

set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
LIB="$ROOT/.agentflow/lib/agentflow.py"
SHARED_RETRY="$ROOT/../_shared/opencode-retry.sh"
export PATH="$ROOT/.agentflow/bin:$PATH"
ROUND_ID="${1:-}"
if [[ -z "$ROUND_ID" ]]; then echo "usage: $(basename "$0") <round-id>" >&2; exit 2; fi
ROUND_DIR="$ROOT/.agentflow/rounds/$ROUND_ID"
LOG_DIR="$ROUND_DIR/logs"
mkdir -p "$LOG_DIR"
MODEL="${AGENTFLOW_EXECUTOR_MODEL:-$(python3 "$LIB" config-value executor.model 2>/dev/null || true)}"; MODEL="${MODEL:-mimo-v2.5}"
PROVIDER="${AGENTFLOW_EXECUTOR_PROVIDER:-$(python3 "$LIB" config-value executor.provider 2>/dev/null || true)}"; PROVIDER="${PROVIDER:-xiaomi-token-plan-sgp}"
CLI_MODEL="${AGENTFLOW_EXECUTOR_CLI_MODEL:-${AGENTFLOW_EXECUTOR_MODEL:-$(python3 "$LIB" config-value executor.cli_model 2>/dev/null || true)}}"; CLI_MODEL="${CLI_MODEL:-$MODEL}"
if [[ ! -f "$SHARED_RETRY" ]]; then echo "SHARED_RETRY_HELPER_MISSING: $SHARED_RETRY" >&2; exit 1; fi
# shellcheck source=/dev/null
. "$SHARED_RETRY"
real_opencode_prompt(){ local instruction="$1" mode="$2" output="$3"; cat "$instruction"; printf '\n\nRound ID: %s\nRound dir: %s\nRequired output: %s\nMode: %s\nExecutor model: %s\nProvider: %s\nCLI model: %s\n' "$ROUND_ID" "$ROUND_DIR" "$output" "$mode" "$MODEL" "$PROVIDER" "$CLI_MODEL"; }
execute_opencode(){ local mode="$1" instruction="$2" output="$3" outlog="$4" errlog="$5"; if ! command -v opencode >/dev/null 2>&1; then echo "OPENCODE_NOT_FOUND" >"$errlog"; return 127; fi; local prompt; prompt="$(real_opencode_prompt "$instruction" "$mode" "$output")"; supertest_run_with_retry "$outlog" "$errlog" "" opencode run --model "$CLI_MODEL" "$prompt"; return $?; }
validate_or_fail(){ local kind="$1" output="$2" errlog="$3"; if [[ ! -f "$output" ]]; then echo "EXECUTOR_FAILED_NO_ARTIFACT: $output" >>"$errlog"; "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" FAILED error=EXECUTOR_FAILED_NO_ARTIFACT >/dev/null || true; exit 1; fi; if ! "$ROOT/.agentflow/bin/validate-artifact" "$kind" "$output" >>"$errlog" 2>&1; then echo "EXECUTOR_INVALID_ARTIFACT: $output" >>"$errlog"; "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" FAILED error=EXECUTOR_INVALID_ARTIFACT >/dev/null || true; exit 1; fi; }

INSTRUCTION="$ROOT/.agentflow/prompts-or-instructions/opencode-implement-only.md"; PLAN="$ROUND_DIR/04-approved-plan.md"; OUTPUT="$ROUND_DIR/05-implementation-report.json"; STDOUT_LOG="$LOG_DIR/implement-with-opencode.stdout.log"; STDERR_LOG="$LOG_DIR/implement-with-opencode.stderr.log"
if [[ ! -f "$PLAN" ]]; then echo "APPROVED_PLAN_MISSING: $PLAN" >"$STDERR_LOG"; exit 1; fi
"$ROOT/.agentflow/bin/update-state" "$ROUND_ID" IMPLEMENTING >/dev/null
if ! execute_opencode IMPLEMENT_ONLY "$INSTRUCTION" "$OUTPUT" "$STDOUT_LOG" "$STDERR_LOG"; then echo "EXECUTOR_FAILED_NO_ARTIFACT" >>"$STDERR_LOG"; "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" FAILED error=EXECUTOR_FAILED_NO_ARTIFACT >/dev/null || true; exit 1; fi
validate_or_fail implementation-report "$OUTPUT" "$STDERR_LOG"
status="$(python3 -c "import json; print(json.load(open('$OUTPUT'))['status'])")"
if [[ "$status" == "PLAN_MISMATCH" ]]; then "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" PLAN_MISMATCH implementation_report=".agentflow/rounds/$ROUND_ID/05-implementation-report.json" >/dev/null; else "$ROOT/.agentflow/bin/update-state" "$ROUND_ID" IMPLEMENTED implementation_report=".agentflow/rounds/$ROUND_ID/05-implementation-report.json" >/dev/null; fi
"$ROOT/.agentflow/bin/write-envelope" implementation-report "$OUTPUT" >/dev/null
echo "Wrote $OUTPUT"
