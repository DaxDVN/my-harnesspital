#!/usr/bin/env python3
import importlib.util
import sys
from pathlib import Path
sys.dont_write_bytecode = True
module_path = Path(__file__).resolve().parents[1] / "lib" / "agentflow.py"
spec = importlib.util.spec_from_file_location("agentflow_lib", module_path)
module = importlib.util.module_from_spec(spec)
assert spec.loader is not None
spec.loader.exec_module(module)
raise SystemExit(module.main([Path(__file__).name, *sys.argv[1:]]))
